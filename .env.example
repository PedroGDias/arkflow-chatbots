# WhatsApp Cloud API (Meta for Developers > your app > WhatsApp > API Setup)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any string you choose — must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=

# Arkflow ERP project — catalog, customers, and orders live here
ERP_SUPABASE_URL=
ERP_SUPABASE_SERVICE_ROLE_KEY=
ARKFLOW_CLIENT_ID=

# OpenAI (for voice note transcription via Whisper)
OPENAI_API_KEY=

# Comma-separated phone numbers (WhatsApp "from" format, e.g. 85269369092) the bot will respond to.
# Anyone else's message is silently ignored.
ALLOWED_PHONE_NUMBERS=
